{
  "name": "@rona/nix-overstory-cli",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "show-manifest": "bun --eval \"console.log(await Bun.file('nix/package-manifest.json').text())\"",
    "sync:source": "bun run sync:npm-source",
    "sync:manifest": "bun run sync:npm-source",
    "sync:npm-source": "bun run scripts/sync-from-npm.ts",
    "sync:github-source": "bun run scripts/sync-from-github.ts",
    "sync:bun-deps": "echo 'Regenerate bun.nix from the pinned overstory source bun.lock.'"
  },
  "dependencies": {
    "@os-eco/overstory-cli": "0.9.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "bun2nix": "2.0.8"
  }
}
